# ============================================================
# ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ============================================================

# Required: Your Anthropic API key
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Override the Claude model used for post generation
# Defaults to claude-sonnet-4-6
# Options: claude-opus-4-7, claude-sonnet-4-6, claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: NewsAPI key for additional news sources
# Get a free key at https://newsapi.org/
# After adding this key, set enabled: true in config/sources.yaml under optional_apis.newsapi
NEWSAPI_KEY=
