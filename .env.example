# ============================================================
# ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ============================================================

# ── Claude / Anthropic ─────────────────────────────────────
# Not required if you run inside Claude Code (uses OAuth automatically).
# Required for standalone use outside of Claude Code.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Claude model used for post generation.
# Alias "sonnet" (default) resolves to the latest Sonnet via Claude Code CLI.
# For SDK use, set the full model ID: claude-sonnet-4-6 / claude-opus-4-7
ANTHROPIC_MODEL=sonnet

# ── Notion integration ─────────────────────────────────────
# Pushes generated post drafts to your Notion "LinkedIn Post Ideas" page.
#
# Setup steps:
#   1. Go to https://www.notion.so/my-integrations → New integration (Internal)
#   2. Copy the "Internal Integration Token" → paste as NOTION_API_KEY below
#   3. Open your LinkedIn Post Ideas Notion page
#   4. "..." menu → Connections → connect your integration
#   5. Copy the 32-char page ID from the URL → paste as NOTION_PAGE_ID below
#
# If left blank, the pipeline skips Notion and only saves posts as local .md files.
NOTION_API_KEY=
NOTION_PAGE_ID=34a50188f130816280e1f9ec2ef84a0c

# ── Optional: NewsAPI ──────────────────────────────────────
# Broader news coverage beyond RSS feeds.
# Free key at https://newsapi.org/
# After adding, set enabled: true in config/sources.yaml → optional_apis.newsapi
NEWSAPI_KEY=
